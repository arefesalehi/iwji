# Copy to .env and fill in. On Liara, set these in the app console (Variables).

# Public URL of this Next app (no trailing slash). Required on Liara for correct upload image URLs.
NEXT_PUBLIC_APP_URL=https://YOUR_APP.liara.run

# Optional duplicate for server-only code
# APP_URL=https://YOUR_APP.liara.run

# MongoDB - Use Liara Database service or external MongoDB
MONGODB_URI=mongodb://user:password@host:port/iwji

# JWT and other secrets from your existing .env
# AccessTokenSecretKey=
# RefreshTokenSecretKey=

# Zarinpal callback must use production URL when deployed
# ZARINPAL_PAYMENT_CALLBACK_URL=https://YOUR_APP.liara.run/api/checkout/verify

# ===== Liara Object Storage Configuration =====
# Get these from Liara dashboard → Storage → Object Storage
LIARA_ACCESS_KEY=your_access_key
LIARA_SECRET_KEY=your_secret_key
LIARA_BUCKET_NAME=your_bucket_name
LIARA_BUCKET_URL=https://your-bucket-name.storage.iran.liara.space
LIARA_ENDPOINT=https://storage.iran.liara.space

# IPPanel SMS (signup / login OTP) — never commit real values; set in Liara Variables.
# SMS_IPPANEL_USER=
# SMS_IPPANEL_PASS=
# SMS_IPPANEL_FROM_NUM=3000505
# SMS_IPPANEL_PATTERN_CODE=
